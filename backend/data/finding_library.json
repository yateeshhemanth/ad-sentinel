{
  "version": "1.0.0",
  "last_updated": "2026-02",
  "description": "ADSentinel finding library — AD security checks mapped to CIS, NIST, ISO 27001, SOC2, MITRE ATT&CK",
  "findings": [
    {
      "id": "AD-PWD-001",
      "category": "password",
      "title": "Account with non-expiring password",
      "description": "The DONT_EXPIRE_PASSWORD flag (ADS_UF_DONT_EXPIRE_PASSWD) is set. The password never rotates, increasing exposure window if the credential is compromised.",
      "severity": "high",
      "ldap_filter": "(&(objectClass=user)(userAccountControl:1.2.840.113556.1.4.803:=65536)(!(objectClass=computer)))",
      "ldap_attributes": [
        "sAMAccountName",
        "userAccountControl",
        "pwdLastSet",
        "memberOf"
      ],
      "remediation": "Remove the DONT_EXPIRE_PASSWORD flag via ADUC or: Set-ADUser <user> -PasswordNeverExpires $false. Exception: service accounts managed by a PAM vault.",
      "risk_score": 7.2,
      "compliance": {
        "cis_v8": [
          "5.2"
        ],
        "nist_800_53": [
          "IA-5",
          "IA-5(1)"
        ],
        "iso_27001": [
          "A.9.4.3"
        ],
        "soc2": [
          "CC6.1"
        ],
        "mitre": [
          {
            "id": "T1078",
            "name": "Valid Accounts"
          },
          {
            "id": "T1078.002",
            "name": "Domain Accounts"
          }
        ]
      },
      "threshold_param": "enableNonExpiringCheck",
      "binary": true
    },
    {
      "id": "AD-PWD-002",
      "category": "password",
      "title": "Account with blank / null password",
      "description": "The PASSWD_NOTREQD flag is set, or the password hash is LM empty hash. Account can be authenticated without a password.",
      "severity": "critical",
      "ldap_filter": "(&(objectClass=user)(userAccountControl:1.2.840.113556.1.4.803:=32)(!(objectClass=computer)))",
      "ldap_attributes": [
        "sAMAccountName",
        "userAccountControl",
        "distinguishedName"
      ],
      "remediation": "Set a strong password immediately. Clear the PASSWD_NOTREQD flag. Investigate why it was set.",
      "risk_score": 9.8,
      "compliance": {
        "cis_v8": [
          "5.2",
          "5.3"
        ],
        "nist_800_53": [
          "IA-5",
          "AC-2"
        ],
        "iso_27001": [
          "A.9.4.3",
          "A.9.2.1"
        ],
        "soc2": [
          "CC6.1",
          "CC6.2"
        ],
        "mitre": [
          {
            "id": "T1110",
            "name": "Brute Force"
          },
          {
            "id": "T1110.003",
            "name": "Password Spraying"
          }
        ]
      },
      "threshold_param": "enableBlankPasswordCheck",
      "binary": true
    },
    {
      "id": "AD-PWD-003",
      "category": "password",
      "title": "Password not required flag set",
      "description": "UF_PASSWD_NOTREQD (0x20) is set. The domain password policy is not enforced for this account.",
      "severity": "critical",
      "ldap_filter": "(&(objectClass=user)(userAccountControl:1.2.840.113556.1.4.803:=32))",
      "ldap_attributes": [
        "sAMAccountName",
        "userAccountControl",
        "description"
      ],
      "remediation": "Clear the flag: Get-ADUser <user> | Set-ADUser -PasswordNotRequired $false",
