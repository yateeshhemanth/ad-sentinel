    {
      "id": "AD-PRIV-002",
      "category": "privilege",
      "title": "Kerberoastable service account",
      "description": "User accounts with ServicePrincipalName (SPN) set are vulnerable to offline password cracking via Kerberoasting (T1558.003).",
      "severity": "high",
      "ldap_filter": "(&(objectClass=user)(servicePrincipalName=*)(!(cn=krbtgt))(!(userAccountControl:1.2.840.113556.1.4.803:=2)))",
      "ldap_attributes": [
        "sAMAccountName",
        "servicePrincipalName",
        "memberOf",
        "pwdLastSet"
      ],
      "remediation": "Use Group Managed Service Accounts (gMSA). For existing accounts: use strong 25+ char passwords and monitor TGS requests.",
      "risk_score": 8.5,
      "compliance": {
        "cis_v8": [
          "5.4",
          "4.7"
        ],
        "nist_800_53": [
          "IA-5",
          "AC-6"
        ],
        "iso_27001": [
          "A.9.2.3"
        ],
        "soc2": [
          "CC6.1"
        ],
        "mitre": [
          {
            "id": "T1558",
            "name": "Steal or Forge Kerberos Tickets"
          },
          {
            "id": "T1558.003",
            "name": "Kerberoasting"
          }
        ]
      },
      "threshold_param": "enableKerberoastCheck",
      "binary": true
    },
