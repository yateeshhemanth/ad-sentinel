    {
      "id": "AD-PWD-004",
      "category": "password",
      "title": "Password older than 180 days",
      "description": "Account password has not been changed in over 180 days, significantly exceeding recommended rotation schedules.",
      "severity": "high",
      "ldap_filter": "(&(objectClass=user)(!(userAccountControl:1.2.840.113556.1.4.803:=2))(pwdLastSet<=__180_DAYS_AGO__))",
      "ldap_attributes": [
        "sAMAccountName",
        "pwdLastSet",
        "lastLogonTimestamp",
        "department"
