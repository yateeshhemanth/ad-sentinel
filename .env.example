# ── ADSentinel Environment Configuration ─────────────────────────
# Copy this to .env and fill in your values

# Database
DB_NAME=adsentinel
DB_USER=adsentinel
DB_PASSWORD=change_me_strong_password_123

# Redis
REDIS_PASSWORD=change_me_redis_password

# JWT
JWT_SECRET=change_me_jwt_secret_minimum_32_characters_long
JWT_EXPIRES_IN=8h

# Field-level encryption key for AD bind passwords (AES-256-GCM)
# Generate with: openssl rand -hex 32
FIELD_ENCRYPTION_KEY=change_me_generate_with_openssl_rand_hex_32

# Email (for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@yourcompany.com

# App URLs
APP_ENV=development
FRONTEND_URL=http://localhost
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost
HTTP_PORT=80
HTTPS_PORT=443

# Default admin user (created on first run)
ADMIN_EMAIL=admin@adsentinel.local
ADMIN_PASSWORD=Admin@123456!
